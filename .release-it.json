{
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  },
  "git": {
    "requireBranch": ["main", "beta"],
    "commitMessage": "chore(release): ${version} [skip ci]",
    "tagName": "v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": true,
    "provenance": true,
    "skipChecks": true
  },
  "hooks": {
    "before:npm": "npm run build"
  }
}